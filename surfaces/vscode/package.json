{
  "name": "agentnet-vscode",
  "displayName": "AgentNet",
  "description": "Chat with Claude Code and Codex in VS Code, with portable sessions and a built-in marketplace of agent skills.",
  "version": "0.1.0",
  "publisher": "iqlabs",
  "license": "Apache-2.0",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0d0d10",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/IQCoreTeam/AgentNet.git",
    "directory": "surfaces/vscode"
  },
  "bugs": {
    "url": "https://github.com/IQCoreTeam/AgentNet/issues"
  },
  "homepage": "https://github.com/IQCoreTeam/AgentNet",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "keywords": [
    "claude",
    "codex",
    "agent",
    "skills",
    "chat"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "agentnet.openChat",
        "title": "Open Chat",
        "category": "AgentNet",
        "icon": {
          "light": "media/title-icon-light.svg",
          "dark": "media/title-icon-dark.svg"
        }
      },
      {
        "command": "agentnet.newChat",
        "title": "New Chat (new tab)",
        "category": "AgentNet",
        "icon": "$(add)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentnet",
          "title": "AgentNet",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "agentnet": [
        {
          "id": "agentnet.home",
          "name": "Chats",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "agentnet.openChat",
          "group": "navigation@100"
        }
      ],
      "view/title": [
        {
          "command": "agentnet.newChat",
          "when": "view == agentnet.home",
          "group": "navigation@1"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@iqlabs-official/agent-sdk": "workspace:*"
  }
}
