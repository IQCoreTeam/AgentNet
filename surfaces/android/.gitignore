# Gradle / Android build output
.gradle/
build/
local.properties
*.apk
*.aab

# Shared debug keystore — distributed out-of-band (private channel), NEVER committed to
# this public repo. build.gradle uses it when present; see android-clean-reinstall.md.
*.keystore
*.jks

# Runtime payload built by the release pipeline (large native binaries / images), never
# committed (see scripts/build-assets.sh).
# proot + loader + libs: libproot.so, libloader*.so, libtalloc.so, libandroid-shmem.so
app/src/main/jniLibs/
# legacy: pre-jniLibs proot tree (no longer produced)
app/src/main/assets/proot-*
app/src/main/assets/rootfs-*
app/src/main/assets/agentnet-server.tar
# rootfs now ships in the Play Asset Delivery pack (:rootfs) — same heavy tar, still generated
# (build-assets.sh) / CI-staged, never committed.
rootfs/src/main/assets/rootfs-*
.assets-build/
